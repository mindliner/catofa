# Listener port to expose from the container
CATOFA_PORT=4077

# Where Catofa stores tickets + uploads inside the container
CATOFA_DATA_DIR=/var/lib/catofa

# Optional overrides for backend defaults
# CATOFA_TICKETS=/var/lib/catofa/tickets.json
# CATOFA_FAUCET_URL=http://127.0.0.1:8080
# LAKESIDE_ARGS=
# LAKESIDE_BIN=/usr/local/bin/lakeside
# LAKESIDE_CWD=/opt/lakeside

# Uncomment to tweak wallet directory (default: /home/node/.lakeside)
# CATOFA_WALLET=/home/node/.lakeside
